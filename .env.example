# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME=SocialMediaAgent
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-string

# ─────────────────────────────────────────────
# Database — Supabase (recommended free option)
# Get from: Supabase → Settings → Database → Connection String
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Local PostgreSQL alternative:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/social_media_agent
# DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/social_media_agent

# ─────────────────────────────────────────────
# Redis
# Upstash free tier: https://upstash.com
# OR local: redis://localhost:6379/0
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─────────────────────────────────────────────
# AI Provider — choose ONE block
# ─────────────────────────────────────────────

# Option 1: Groq (free tier, 14,400 req/day) — https://console.groq.com
AI_PROVIDER=groq
AI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=gsk_your-groq-key-here
OPENAI_MODEL=llama-3.3-70b-versatile

# Option 2: Ollama (fully local, no key) — https://ollama.com
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.2

# Option 3: OpenAI (paid) — https://platform.openai.com
# AI_PROVIDER=openai
# AI_BASE_URL=
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4

# ─────────────────────────────────────────────
# Meta / Facebook
# Get from: https://developers.facebook.com → Your App → Settings → Basic
# ─────────────────────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:8000/api/auth/meta/callback
FACEBOOK_GRAPH_API_VERSION=v18.0

# ─────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────
DAILY_POST_GENERATION_HOUR=6
TIMEZONE=UTC
